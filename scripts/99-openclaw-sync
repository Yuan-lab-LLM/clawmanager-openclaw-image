#!/bin/bash

# Path Definitions
CONFIG_FILE="/config/.openclaw/openclaw.json"
DEFAULT_SOURCE="/defaults/.openclaw"
AUTOSTART_DIR="/config/.config/autostart"
AUTOSTART_DEFAULT="/defaults/.config/autostart"
AGENT_GATEWAY_AUTOSTART="$AUTOSTART_DIR/openclaw-gateway.desktop"

# 1. Initial Sync from Defaults
if [ ! -d "/config/.openclaw" ] || [ ! -f "$CONFIG_FILE" ]; then
    echo "[OpenClaw] Syncing config from defaults..."
    mkdir -p /config/.openclaw
    cp -rp "$DEFAULT_SOURCE/." /config/.openclaw/
fi

# 1b. XFCE login autostart: when agent mode is enabled, the agent must be the only
# process manager for openclaw, so remove the legacy desktop autostart entry.
if [ "${CLAWMANAGER_AGENT_ENABLED:-}" = "true" ] && [ -f "$AGENT_GATEWAY_AUTOSTART" ]; then
    echo "[OpenClaw] Removing legacy XFCE gateway autostart because agent mode is enabled"
    rm -f "$AGENT_GATEWAY_AUTOSTART"
fi

# 1c. XFCE login autostart: install missing *.desktop from image (once per file; /config is abc's $HOME)
if [ -d "$AUTOSTART_DEFAULT" ]; then
    for f in "$AUTOSTART_DEFAULT"/*.desktop; do
        [ -f "$f" ] || continue
        base=$(basename "$f")
        if [ "${CLAWMANAGER_AGENT_ENABLED:-}" = "true" ] && [ "$base" = "openclaw-gateway.desktop" ]; then
            continue
        fi
        dest="$AUTOSTART_DIR/$base"
        if [ ! -f "$dest" ]; then
            echo "[OpenClaw] Installing XFCE autostart: $base"
            mkdir -p "$AUTOSTART_DIR"
            cp -f "$f" "$dest"
            chown abc:abc "$dest"
        fi
    done
fi

# 2. Dynamic Environment Injection
echo "[OpenClaw] Starting environment injection..."

# --- Base URL ---
if [ -n "$CLAWMANAGER_LLM_BASE_URL" ]; then
    echo "-> Injecting Base URL..."
    sed -i "s@\"baseUrl\":[[:space:]]*\"[^\"]*\"@\"baseUrl\": \"$CLAWMANAGER_LLM_BASE_URL\"@g" "$CONFIG_FILE"
fi

# --- API Key ---
if [ -n "$CLAWMANAGER_LLM_API_KEY" ]; then
    echo "-> Injecting API Key..."
    sed -i "s@\"apiKey\":[[:space:]]*\"[^\"]*\"@\"apiKey\": \"$CLAWMANAGER_LLM_API_KEY\"@g" "$CONFIG_FILE"
fi

# --- Model ID (Full Replace with auto/ preservation) ---
if [ -n "$CLAWMANAGER_LLM_MODEL" ]; then
    echo "-> Injecting Model ID: $CLAWMANAGER_LLM_MODEL"

    # A. Replace "id": "xxx"
    sed -i "s@\"id\":[[:space:]]*\"[^\"]*\"@\"id\": \"$CLAWMANAGER_LLM_MODEL\"@g" "$CONFIG_FILE"

    # B. Replace "primary": "auto/xxx" (Preserves auto/)
    sed -i "s@\"primary\":[[:space:]]*\"auto/[^\"]*\"@\"primary\": \"auto/$CLAWMANAGER_LLM_MODEL\"@g" "$CONFIG_FILE"

    # C. Replace Key-style "auto/xxx": {} (Preserves auto/)
    sed -i "s@\"auto/[^\"]*\":[[:space:]]*{}@\"auto/$CLAWMANAGER_LLM_MODEL\": {}@g" "$CONFIG_FILE"
fi

# --- Channels (JSON object: feishu / slack / telegram / ... merged into channels) ---
if [ -n "$CLAWMANAGER_OPENCLAW_CHANNELS_JSON" ]; then
    echo "-> Injecting channel config..."
    export OPENCLAW_CONFIG_FILE="$CONFIG_FILE"
    node <<'NODE'
const fs = require('fs');
const path = process.env.OPENCLAW_CONFIG_FILE;
const raw = process.env.CLAWMANAGER_OPENCLAW_CHANNELS_JSON;
let parsed;
try {
  parsed = JSON.parse(raw);
} catch (e) {
  console.error('[OpenClaw] CLAWMANAGER_OPENCLAW_CHANNELS_JSON is not valid JSON:', e.message);
  process.exit(1);
}
if (parsed === null || typeof parsed !== 'object' || Array.isArray(parsed)) {
  console.error('[OpenClaw] CLAWMANAGER_OPENCLAW_CHANNELS_JSON must be a JSON object.');
  process.exit(1);
}
let cfg;
try {
  cfg = JSON.parse(fs.readFileSync(path, 'utf8'));
} catch (e) {
  console.error('[OpenClaw] Failed to read config:', e.message);
  process.exit(1);
}
if (!cfg.channels) cfg.channels = {};
Object.assign(cfg.channels, parsed);
const tmp = path + '.tmp.' + process.pid;
const out = JSON.stringify(cfg, null, 4) + '\n';
fs.writeFileSync(tmp, out, 'utf8');
fs.renameSync(tmp, path);
NODE
fi

# 3. Final Permissions Check
chown -R abc:abc /config/.openclaw
echo "[OpenClaw] All tasks completed."
